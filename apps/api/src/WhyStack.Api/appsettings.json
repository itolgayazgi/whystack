{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Every refresh ROTATES the token, and rotation writes a row. An active device refreshes about 32
  // times a day, so 10,000 users on two devices would write ~234 million rows a year — and nothing
  // would delete them. This bounds the table: rows past ExpiresAtUtc are removed, which is safe
  // because an expired token is already refused on expiry alone.
  //
  // BatchSize stays below SQL Server's lock-escalation threshold (~5,000 row locks). Cross it and the
  // delete takes a TABLE lock, and nobody can sign in until it finishes.
  "SessionMaintenance": {
    "Enabled": true,
    "Interval": "01:00:00",
    "BatchSize": 2000,
    "RetentionAfterExpiry": "7.00:00:00"
  },

  // Exactly which web origins may call this API with credentials. No wildcard — the browser refuses
  // "*" together with Access-Control-Allow-Credentials anyway, and that refusal is a feature: it means
  // no deployment can accidentally let any site on the internet make authenticated calls on a logged-in
  // user's behalf.
  //
  // 8081 is Expo's dev server. Production origins are supplied per environment.
  "Cors": {
    "AllowedOrigins": ["http://localhost:8081"]
  },

  // The real mail sender. Overridden entirely in Development, where Mailpit catches everything.
  //
  // Port 465 with SslOnConnect: TLS from the first byte, so there is no plaintext phase for anybody to
  // interfere with. Port 587 with StartTls would also be correct — what is NOT correct, and what this
  // code used to do, is "TLS if the server offers it": strip the STARTTLS advertisement from the
  // greeting and the reset link goes out in the clear, silently, with nothing in any log.
  //
  // Sending through Hostinger's own SMTP is also what makes SPF pass: the domain's SPF record is
  // `v=spf1 include:_spf.mail.hostinger.com ~all`, so their servers are the ones authorised to send as
  // whystack.dev. Send from anywhere else and confirmation mail starts landing in spam — and a
  // password-reset email in a spam folder is an account nobody can recover.
  "Smtp": {
    "Host": "smtp.hostinger.com",
    "Port": 465,
    "Security": "SslOnConnect",
    "Username": "info@whystack.dev",
    "FromAddress": "info@whystack.dev",
    "FromName": "WhyStack"

    // Password is deliberately ABSENT, like the JWT signing key. It goes in user secrets locally and in
    // a secret store in production. A mailbox password in a tracked file is a mailbox password in the
    // git history forever — and this mailbox can send mail AS the product, which is everything an
    // attacker needs to phish the product's own users with a real, SPF-passing, DKIM-signed email.
  },

  // Where the educational Markdown is. `07`: "Markdown may exist in files. The database stores metadata,
  // relationships and publishing state." The database holds the path and the hash; the words are here.
  //
  // The content SHIPS WITH the API — it is part of the deployed artefact, not a mounted volume. Deploy the
  // two separately and a row will point at a file this host does not have: a topic that 404s at read time
  // with no explanation, and no way to tell which half is stale.
  // In production the content sits beside the binary. Development overrides this to the repository's own
  // content/ directory, so an edit to a Markdown file is visible on the next request — no copy step.
  "Content": {
    "Root": "content"
  },

  "App": {
    // Where the CLIENT lives — the links in confirmation and reset emails are clicked by a human in a
    // browser and must land on a screen, not on a JSON endpoint. Overridden per environment.
    "ClientBaseUrl": "http://localhost:8081"
  },

  "Jwt": {
    "Issuer": "https://api.whystack.dev",
    "Audience": "https://whystack.dev"

    // SigningKey is deliberately ABSENT. It belongs in user secrets locally and in a secret store in
    // production. A signing key in a tracked file is a signing key in the git history forever, and
    // anyone holding it can mint a valid token for any user — including an Administrator.
    //
    // The app refuses to start without it (see AddInfrastructure), which is the correct failure: an
    // API that boots with no signing key and only fails when someone signs in is worse than one that
    // does not boot.
    //
    // scripts/setup/dev-database.ps1 generates one into user secrets.
  }
}
