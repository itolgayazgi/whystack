{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Mailpit, from infrastructure/docker/docker-compose.yml. It catches every message and delivers
  // none of them; read them at http://localhost:8025.
  //
  // No credentials, and TLS off: it is a loopback-only container with no certificate. Both of those
  // are wrong everywhere else, which is why they live in the Development file and not the shared one.
  "Smtp": {
    "Host": "127.0.0.1",
    "Port": 1025,
    "UseTls": false,
    "FromAddress": "no-reply@whystack.local",
    "FromName": "WhyStack (dev)"
  }
}
