# Copy to .env — or just run scripts/setup/dev-database.ps1, which writes it for you with a real
# random password. .env is gitignored and must stay that way.
#
# This value is a PLACEHOLDER. It is not a password anyone uses, and SQL Server will reject it
# anyway (it needs 8+ characters with upper, lower, digit and symbol). Do not "fix" it by inventing
# one here — the script generates one, so the database and the API's user secrets cannot drift.

MSSQL_SA_PASSWORD=REPLACE_ME_RUN_THE_SETUP_SCRIPT
