{
  "name": "whystack",
  "version": "0.1.0",
  "private": true,
  "description": "WhyStack — an engineering learning platform that teaches why technologies exist.",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "content:validate": "turbo run content:validate",

    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:design": "node scripts/lint/no-hardcoded-design-values.mjs",

    "api": "dotnet run --project apps/api/src/WhyStack.Api",
    "api:test": "dotnet test apps/api/WhyStack.sln",
    "api:format": "dotnet format apps/api/WhyStack.sln --verify-no-changes",

    "verify": "pnpm lint && pnpm lint:design && pnpm typecheck && pnpm test",
    "verify:all": "pnpm verify && pnpm api:format && pnpm api:test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "turbo": "^2.5.0"
  }
}
